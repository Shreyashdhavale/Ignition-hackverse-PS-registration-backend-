generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ProblemStatement {
  id        String   @id
  track     Int
  psNumber  Int
  title     String
  createdAt DateTime @default(now())

  selections PSSelection[]
}

model TeamRegistration {
  id String @id @default(uuid())

  // 🔹 EXACT CSV COLUMN NAMES
  registrationId     String   @unique
  teamName           String
  teamSize           Int
  pptLink            String?
  paymentScreenshot  String?
  registrationStatus String?
  leaderId           String?
  createdAt          DateTime?

  // 🔹 Relation
  selections         PSSelection[]
}

model PSSelection {
  id String @id @default(uuid())

  registrationId String
  psId           String

  createdAt      DateTime @default(now())

  // 🔹 Relations (DO NOT CHANGE as per your request)
  team           TeamRegistration @relation(fields: [registrationId], references: [registrationId])
  problemStatement ProblemStatement @relation(fields: [psId], references: [id])

  @@unique([registrationId, psId])
}