# Database Configuration
# For Supabase PostgreSQL Setup:
# 1. Go to your Supabase project dashboard
# 2. Find your database credentials in Project Settings > Database
# 3. Use the pooled connection (pgbouncer) for DATABASE_URL
# 4. Use the direct connection for DIRECT_URL (required for Prisma migrations)

# DATABASE_URL: For queries (use connection pooler for better performance)
DATABASE_URL="postgresql://[user]:[password]@[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL: Must be direct DB connection (not pooler) for Prisma migrations
DIRECT_URL="postgresql://[user]:[password]@db.[region].supabase.co:5432/postgres?sslmode=require"

# Server Configuration
# PORT: Server listening port (default: 5000)
PORT=5000

# CORS_ORIGIN: Frontend origin for CORS (default: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000
